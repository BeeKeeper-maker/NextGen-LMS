# Dependencies - will be installed fresh via bun install
node_modules

# Next.js build output - will be rebuilt in container
.next

# Git history - not needed in container
.git
.gitignore

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment files (secrets handled by Coolify)
.env
.env.local
.env.development
.env.production

# Documentation and config
README.md
LICENSE
*.md

# Test files
__tests__
*.test.*
*.spec.*
coverage

# Build artifacts and caches
.turbo
.vercel
.cache

# Scratch and temp files
tmp
temp
